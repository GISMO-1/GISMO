{
  "allowed_tools": [
    "echo",
    "write_note",
    "read_file",
    "write_file",
    "list_dir",
    "run_shell",
    "memory.put",
    "memory.delete",
    "memory.read"
  ],
  "fs": {
    "base_dir": "."
  },
  "memory": {
    "allow": {
      "memory.put": ["run:*", "project:*", "global"],
      "memory.delete": ["run:*"],
      "memory.read": ["run:*", "project:*", "global"]
    },
    "require_confirmation": {
      "memory.put": ["project:*", "global"]
    }
  },
  "shell": {
    "base_dir": ".",
    "allowlist": [
      ["git", "status"],
      ["python", "-m", "unittest", "-v"],
      ["make", "test"]
    ]
  }
}
